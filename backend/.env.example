# Flask
FLASK_ENV=development
PORT=5000
SECRET_KEY=change_me_secret_key
JWT_SECRET_KEY=change_me_jwt_secret_key

# Database
# 开发环境默认使用 SQLite: backend/instance/dev.db
# 如需 MySQL，请取消下一行注释并改为你的连接串，例如：
# DEV_DATABASE_URL=mysql+pymysql://username:password@localhost/academic_planning

# Neo4j (可选，若要初始化知识图谱需正确配置并启动 Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# AI / DeepSeek (可选，若需 AI 助手功能请填写)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 上传目录（可选，不填则按程序默认 backend/uploads）
# UPLOAD_FOLDER=backend/uploads
